# ============================================================
# NQT GYM MANAGEMENT - Environment Config Example
# ============================================================
# Hướng dẫn:
#   1. Copy file này thành .env
#   2. Điền giá trị thực vào các biến trống
#   3. Đổi AUTHOR_PREFIX thành prefix của bạn
# ============================================================

# --- THÀNH VIÊN ---
# Đặt prefix của bạn ở đây trước khi bắt đầu làm việc
# nqt = Nguyễn Quang Tâm
# nxv = Nguyễn Xuân Vinh
AUTHOR_PREFIX=nqt

# --- FLASK ---
FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=your-secret-key-here

# --- DATABASE (SQL Server) ---
DB_SERVER=localhost
DB_NAME=nqtam_project4
DB_USER=sa
DB_PASSWORD=your-db-password
DB_DRIVER=ODBC+Driver+17+for+SQL+Server

# --- JWT ---
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ACCESS_TOKEN_EXPIRES=3600

# --- EMAIL SMTP ---
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-email-app-password

# --- UPLOAD ---
UPLOAD_FOLDER=backend/static/uploads
MAX_CONTENT_LENGTH=10485760
